---
interface Props {
  pageName: string;
  /** When "light", breadcrumb uses black text (for cream/white sections). Default is dark (white text). */
  theme?: 'dark' | 'light';
}

const { pageName, theme = 'dark' } = Astro.props;
---

<p class="solutions-directory" data-theme={theme}>
  <span class="directory-label">SOLUTIONS / </span>
  <span class="directory-page">{pageName.toUpperCase()}</span>
</p>

<style>
  .solutions-directory {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 2rem 0;
    color: #ffffff;
  }

  .directory-label {
    color: #ffffff;
  }

  .directory-page {
    color: var(--color-accent);
  }

  .solutions-directory[data-theme="light"] {
    color: #000000;
  }

  .solutions-directory[data-theme="light"] .directory-label {
    color: #000000;
  }

  .solutions-directory[data-theme="light"] .directory-page {
    color: var(--color-accent);
  }
</style>
