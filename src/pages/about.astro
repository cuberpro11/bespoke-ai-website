---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About - OTC Hedge">
  <div class="page-container" data-navbar-theme="hero">
    <div class="content fade-in">
      <h1>About OTC Hedge</h1>
      <p class="subtitle">Coming Soon</p>
    </div>
  </div>
</Layout>

<style>
  .page-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 80px);
    padding: 2rem;
  }

  .content {
    text-align: center;
    max-width: 800px;
  }

  h1 {
    margin-bottom: 1rem;
  }

  .subtitle {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.6);
  }
</style>
