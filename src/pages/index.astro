---
import Layout from '../layouts/Layout.astro';
---

<Layout title="OTC Hedge - Greatness Coming Soon">
  <div class="hero">
    <div class="hero-content fade-in">
      <h1 class="hero-title">
        Greatness <span class="text-accent">Coming Soon</span>
      </h1>
      <p class="hero-subtitle">
        AI-powered solutions for legal and financial excellence
      </p>
    </div>
  </div>
</Layout>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 80px);
    padding: 2rem;
    text-align: center;
  }

  .hero-content {
    max-width: 900px;
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
    line-height: 1.1;
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    color: rgba(255, 255, 255, 0.7);
    font-weight: 300;
    letter-spacing: 0.01em;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: calc(100vh - 120px);
    }
  }
</style>
