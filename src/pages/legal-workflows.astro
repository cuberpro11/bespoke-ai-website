---
import Layout from '../layouts/Layout.astro';
import SolutionsBreadcrumb from '../components/SolutionsBreadcrumb.astro';

const workflowUseCases = [
  {
    id: 'litigation-prep',
    title: 'Litigation prep',
    description: 'Automatically summarize complaints and prepare counter-arguments and questionnaires to aid in litigation prep.',
  },
  {
    id: 'sharpen-arguments',
    title: 'Sharpen arguments',
    description: 'Analyze testimonies and fact summaries in order to prepare for arguments.',
  },
  {
    id: 'due-diligence',
    title: 'Due diligence',
    description: 'Speed up due diligence by automatically extracting key terms in contracts, term sheets, and agreements.',
  },
  {
    id: 'firm-style-guide',
    title: 'Firm style guide',
    description: 'Scale production of agreements, letters, and memos by embedding firm style guides into workflows.',
  },
  {
    id: 'stakeholder-updates',
    title: 'Stakeholder updates',
    description: 'Distill regulatory changes into comprehensive updates to keep stakeholders informed.',
  },
];
---

<Layout title="Legal Workflows - Otc edge" description="Streamline the way you work. Design and deploy workflows tailored to your team's expertise with Otc edge.">
  <!-- Hero: black bg, white text. Directory like other solutions pages. -->
  <section class="workflows-hero" data-navbar-theme="dark">
    <div class="workflows-hero-inner">
      <SolutionsBreadcrumb pageName="Legal Workflows" />
      <h1 class="workflows-hero-title">Streamline the Way You Work</h1>
      <div class="workflows-hero-visual" role="img" aria-label="Workflow builder interface">
        <span class="workflows-hero-visual-placeholder">Workflow builder</span>
      </div>
      <p class="workflows-hero-sub">
        <strong>Move forward faster.</strong> Design and deploy multi-model agents tailored to your team's expertise and deliver consistent, quality results at scale.
      </p>
    </div>
  </section>

  <!-- Accelerate quality work -->
  <section class="workflows-section workflows-section--cream" data-navbar-theme="dark">
    <div class="workflows-section-inner">
      <div class="workflows-section-header">
        <h2 class="workflows-block-title">Accelerate quality work</h2>
        <p class="workflows-block-sub">Work quickly and efficiently without sacrificing team standards.</p>
      </div>

      <div class="workflows-section-body">
        <div class="workflows-section-visual" aria-hidden="true">
          <span class="workflows-feature-placeholder">Workflow builder</span>
        </div>
        <div class="workflows-section-content">
          <div class="workflows-feature-block">
            <h3 class="workflows-feature-heading">Words to workflows</h3>
            <p class="workflows-feature-desc">Quickly create customized workflows with natural language prompts.</p>
          </div>
          <div class="workflows-feature-block">
            <h3 class="workflows-feature-heading">Improve workflows</h3>
            <p class="workflows-feature-desc">Ask Otc edge to automatically optimize custom workflows for faster performance.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Scale your expertise -->
  <section class="workflows-section workflows-section--cream" data-navbar-theme="dark">
    <div class="workflows-section-inner">
      <div class="workflows-section-header">
        <h2 class="workflows-block-title">Scale your expertise</h2>
        <p class="workflows-block-sub">Amplify your impact with greater capacity to provide differentiated outcomes.</p>
      </div>

      <div class="workflows-section-body">
        <div class="workflows-section-visual" aria-hidden="true">
          <span class="workflows-feature-placeholder">Embedded files & knowledge sources</span>
        </div>
        <div class="workflows-section-content">
          <div class="workflows-feature-block">
            <h3 class="workflows-feature-heading">Embedded context</h3>
            <p class="workflows-feature-desc">Attach golden examples, company templates, and knowledge sources to ground custom workflows.</p>
          </div>
          <div class="workflows-feature-block">
            <h3 class="workflows-feature-heading">Flexible logic</h3>
            <p class="workflows-feature-desc">Handle complex legal tasks with support for conditionals, classification, and multi-step workflows.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Maintain consistency and control -->
  <section class="workflows-section workflows-section--cream" data-navbar-theme="dark">
    <div class="workflows-section-inner">
      <div class="workflows-section-header">
        <h2 class="workflows-block-title">Maintain consistency and control</h2>
        <p class="workflows-block-sub">Drive greater standardization across your organization.</p>
      </div>

      <div class="workflows-section-body">
        <div class="workflows-section-visual" aria-hidden="true">
          <span class="workflows-feature-placeholder">Permissions & access</span>
        </div>
        <div class="workflows-section-content">
          <div class="workflows-feature-block">
            <h3 class="workflows-feature-heading">Sharing workflows</h3>
            <p class="workflows-feature-desc">Send and run custom workflows with other users and teams, including external partners.</p>
          </div>
          <div class="workflows-feature-block">
            <h3 class="workflows-feature-heading">Permissions and governance controls</h3>
            <p class="workflows-feature-desc">Manage workflow access and granular editing permissions based on roles and teams.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Impact quantified: headline left, stats stacked vertically on right (per screenshot) -->
  <section class="workflows-impact" data-navbar-theme="dark">
    <div class="workflows-impact-inner">
      <h3 class="workflows-impact-title">The impact of Workflows, quantified</h3>
      <div class="workflows-impact-stats">
        <div class="workflows-stat">
          <span class="workflows-stat-value">19,000+</span>
          <span class="workflows-stat-label">custom workflows built in Otc edge</span>
        </div>
        <div class="workflows-stat">
          <span class="workflows-stat-value">75%</span>
          <span class="workflows-stat-label">time savings on due diligence with tailored custom workflows at GSK Stockmann</span>
        </div>
        <div class="workflows-stat">
          <span class="workflows-stat-value">800+</span>
          <span class="workflows-stat-label">hours saved by Carvana with structured litigation workflows</span>
        </div>
      </div>
    </div>
  </section>

  <!-- How teams use Workflows: black bg, white text, accordion -->
  <section class="workflows-use-cases" data-navbar-theme="dark">
    <div class="workflows-use-cases-inner">
      <h2 class="workflows-use-cases-title">How teams use Workflows</h2>
      <div class="workflows-accordion">
        <div class="workflows-accordion-list" role="tablist">
          {workflowUseCases.map((item, i) => (
            <div class="workflows-accordion-item" data-active={i === 0}>
              <button
                type="button"
                class="workflows-accordion-trigger"
                role="tab"
                aria-selected={i === 0}
                aria-controls={`panel-${item.id}`}
                id={`tab-${item.id}`}
                data-index={i}
              >
                {item.title}
              </button>
              <div
                id={`panel-${item.id}`}
                class="workflows-accordion-panel"
                role="tabpanel"
                aria-labelledby={`tab-${item.id}`}
                hidden={i !== 0}
              >
                <p class="workflows-accordion-desc">{item.description}</p>
                <div class="workflows-accordion-visual" aria-hidden="true">
                  <span class="workflows-feature-placeholder">Product spot</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA: black bg, white text -->
  <section class="workflows-cta" data-navbar-theme="dark">
    <div class="workflows-cta-inner">
      <h3 class="workflows-cta-title">Unlock Professional Class AI for Your Firm</h3>
      <a href="/#contact" class="workflows-cta-button">Request a Demo</a>
    </div>
  </section>
</Layout>

<script>
  const accordionItems = document.querySelectorAll('.workflows-accordion-item');
  accordionItems.forEach((item) => {
    const trigger = item.querySelector('.workflows-accordion-trigger');
    const panel = item.querySelector('.workflows-accordion-panel');
    if (!trigger || !panel) return;

    trigger.addEventListener('click', () => {
      const wasActive = item.getAttribute('data-active') === 'true';
      accordionItems.forEach((other) => {
        other.setAttribute('data-active', 'false');
        const t = other.querySelector('.workflows-accordion-trigger');
        const p = other.querySelector('.workflows-accordion-panel');
        if (t) t.setAttribute('aria-selected', 'false');
        if (p) p.hidden = true;
      });
      if (!wasActive) {
        item.setAttribute('data-active', 'true');
        trigger.setAttribute('aria-selected', 'true');
        panel.hidden = false;
      }
    });
  });
</script>

<style>
  /* Shared: cream background, black text (not hero) */
  .workflows-section--cream,
  .workflows-impact {
    background-color: #fafaf9;
    color: #000000;
  }

  /* Hero: black bg, white text – matches other solutions pages */
  .workflows-hero {
    background-color: #000000;
    color: #ffffff;
    padding: 4rem 2rem 5rem;
    min-height: auto;
  }

  .workflows-hero-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .workflows-hero-title {
    font-size: clamp(2.75rem, 6vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 2.5rem;
    color: #ffffff;
    font-family: Georgia, 'Times New Roman', serif;
  }

  .workflows-hero-visual {
    width: 100%;
    max-width: 1000px;
    aspect-ratio: 16/10;
    background: linear-gradient(145deg, #2c2420 0%, #1a1614 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 0 2.5rem;
  }

  .workflows-hero-visual-placeholder {
    color: rgba(255, 255, 255, 0.5);
    font-size: 1rem;
  }

  .workflows-hero-sub {
    font-size: clamp(1.0625rem, 1.5vw, 1.25rem);
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
    max-width: 720px;
  }

  .workflows-hero-sub strong {
    font-weight: 700;
    color: #ffffff;
  }

  /* Feature sections */
  .workflows-section {
    padding: 4rem 2rem;
  }

  .workflows-section-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .workflows-section-header {
    display: grid;
    grid-template-columns: minmax(200px, 1fr) 1fr;
    gap: 2rem 3rem;
    align-items: start;
    margin-bottom: 0;
    padding: 3rem 0 2.5rem;
  }

  .workflows-block-title {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
    color: #000000;
  }

  .workflows-block-sub {
    font-size: clamp(1rem, 1.25vw, 1.125rem);
    line-height: 1.55;
    color: #000000;
    margin: 0;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  .workflows-section-body {
    display: grid;
    grid-template-columns: minmax(280px, 1fr) 1fr;
    gap: 2.5rem 3rem;
    align-items: start;
  }

  .workflows-section-visual {
    background: linear-gradient(145deg, #2c2420 0%, #1a1614 100%);
    border-radius: 10px;
    aspect-ratio: 16/10;
    min-height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .workflows-feature-placeholder {
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.9rem;
  }

  .workflows-section-content {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .workflows-feature-block {
    padding: 2rem 0;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .workflows-feature-heading {
    font-size: clamp(1.25rem, 1.5vw, 1.5rem);
    font-weight: 700;
    margin: 0 0 0.75rem;
    color: #000000;
  }

  .workflows-feature-desc {
    font-size: 1rem;
    line-height: 1.55;
    color: #000000;
    margin: 0;
  }

  /* Impact section: headline left, stats vertical on right (Harvey-style) */
  .workflows-impact {
    padding: 4rem 2rem 5rem;
    background-color: #f5f4f0;
  }

  .workflows-impact-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(200px, 1fr) 1fr;
    gap: 3rem 4rem;
    align-items: start;
  }

  .workflows-impact-title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    line-height: 1.2;
    margin: 0;
    color: #000000;
  }

  .workflows-impact-stats {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .workflows-stat {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 2rem 0;
    border-top: 1px solid rgba(0, 0, 0, 0.12);
  }

  .workflows-stat:first-child {
    padding-top: 0;
    border-top: none;
  }

  .workflows-stat-value {
    font-size: clamp(2.25rem, 4vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #000000;
  }

  .workflows-stat-label {
    font-size: 0.95rem;
    line-height: 1.4;
    color: #000000;
  }

  /* How teams use Workflows: black */
  .workflows-use-cases {
    background-color: #000000;
    color: #ffffff;
    padding: 5rem 2rem;
  }

  .workflows-use-cases-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .workflows-use-cases-title {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    margin: 0 0 2.5rem;
    color: #ffffff;
  }

  .workflows-accordion-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .workflows-accordion-item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }

  .workflows-accordion-trigger {
    width: 100%;
    padding: 1.25rem 0;
    text-align: left;
    font-size: clamp(1.1rem, 1.5vw, 1.25rem);
    font-weight: 600;
    color: rgba(255, 255, 255, 0.7);
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    transition: color 0.2s ease;
  }

  .workflows-accordion-item[data-active="true"] .workflows-accordion-trigger {
    color: #ffffff;
  }

  .workflows-accordion-trigger:hover {
    color: #ffffff;
  }

  .workflows-accordion-panel {
    padding: 0 0 1.5rem;
  }

  .workflows-accordion-desc {
    font-size: 1rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.9);
    margin: 0 0 1.5rem;
  }

  .workflows-accordion-visual {
    max-width: 480px;
    aspect-ratio: 16/10;
    background: linear-gradient(145deg, #2c2420 0%, #1a1614 100%);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* CTA */
  .workflows-cta {
    background-color: #000000;
    color: #ffffff;
    padding: 4rem 2rem;
  }

  .workflows-cta-inner {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }

  .workflows-cta-title {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 700;
    margin: 0 0 1.5rem;
    color: #ffffff;
  }

  .workflows-cta-button {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    font-size: 1rem;
    font-weight: 500;
    color: #ffffff;
    background: transparent;
    border: 1px solid #ffffff;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .workflows-cta-button:hover {
    background: #ffffff;
    color: #000000;
  }

  @media (max-width: 900px) {
    .workflows-section-header {
      grid-template-columns: 1fr;
    }

    .workflows-section-body {
      grid-template-columns: 1fr;
    }

    .workflows-impact-inner {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .workflows-hero,
    .workflows-section,
    .workflows-impact {
      padding-left: 1rem;
      padding-right: 1rem;
    }
  }
</style>
